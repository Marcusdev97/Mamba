#!/bin/zsh

# macOS app wrapper for the one canonical launcher.

APP_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
ROOT_DIR="$(cd "$APP_DIR/.." && pwd)"
LAUNCHER="$ROOT_DIR/launchers/Mamba Control Center.command"

if [[ ! -f "$LAUNCHER" ]]; then
  osascript -e 'display dialog "Mamba launcher is missing." buttons {"OK"} default button "OK"'
  exit 1
fi

open -a "/System/Applications/Utilities/Terminal.app" "$LAUNCHER" \
  || open -b com.apple.Terminal "$LAUNCHER" \
  || osascript - "$LAUNCHER" <<'APPLESCRIPT'
on run argv
  tell application "Terminal"
    activate
    do script (quoted form of (item 1 of argv))
  end tell
end run
APPLESCRIPT
